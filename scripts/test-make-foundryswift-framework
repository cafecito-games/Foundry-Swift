#!/usr/bin/env bash
set -euo pipefail

script="scripts/make-foundryswift-framework"
release_workflow=".github/workflows/release.yml"
release_script="scripts/release"

if rg -q 'cat > .*FoundrySwift-Swift\.h|Generated by Apple Swift version|cat > .*module\.modulemap' "$script"; then
    echo "make-foundryswift-framework still handcrafts Swift header or modulemap metadata"
    exit 1
fi

if rg -q 'sh scripts/make-foundryswift-framework' "$release_script"; then
    echo "release script must execute make-foundryswift-framework with its Bash shebang"
    exit 1
fi

for required in \
    "GeneratedModuleMaps" \
    "module-Swift.h" \
    "module.modulemap" \
    'stage_module_metadata "FoundrySwift"' \
    "merge_swift_headers" \
    "install_framework_modulemap" \
    "framework module" \
    "lipo -create"
do
    if ! rg -q "$required" "$script"; then
        echo "make-foundryswift-framework does not reference Xcode-generated metadata via $required"
        exit 1
    fi
done

# Output-level check: greps above only confirm the script mentions the right
# strings. Execute the real install_framework_modulemap function against a
# plain Xcode-generated modulemap and confirm it actually emits a
# `framework module` declaration, so a broken transform fails the test.
modulemap_function=$(awk '/^install_framework_modulemap\(\) \{/,/^\}/' "$script")
if [[ -z "$modulemap_function" ]]; then
    echo "could not locate install_framework_modulemap in $script"
    exit 1
fi

work_dir=$(mktemp -d)
trap 'rm -rf "$work_dir"' EXIT
printf 'module FoundrySwift {\nheader "FoundrySwift-Swift.h"\nexport *\n}\n' > "$work_dir/source.modulemap"
(
    eval "$modulemap_function"
    install_framework_modulemap "$work_dir/source.modulemap" "$work_dir/output.modulemap"
)
if [[ "$(head -1 "$work_dir/output.modulemap")" != "framework module FoundrySwift "* ]]; then
    echo "install_framework_modulemap did not promote the modulemap to a framework module:"
    cat "$work_dir/output.modulemap"
    exit 1
fi

for artifact in \
    "Build/Intermediates.noindex/GeneratedModuleMaps" \
    "Build/Intermediates.noindex/GeneratedModuleMaps-iphoneos" \
    "Build/Intermediates.noindex/GeneratedModuleMaps-iphonesimulator"
do
    if ! rg -q "$artifact" "$release_workflow"; then
        echo "release workflow does not package $artifact for make-foundryswift-framework"
        exit 1
    fi
done
