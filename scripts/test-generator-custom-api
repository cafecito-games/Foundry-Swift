#!/usr/bin/env bash
set -euo pipefail

tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT

api_json="$tmp_dir/extension_api.json"
output_dir="$tmp_dir/generated"
class_filter="$tmp_dir/classes.txt"
available_class_filter="$tmp_dir/available-classes.txt"
builtin_filter="$tmp_dir/builtins.txt"

cat > "$api_json" <<'JSON'
{
  "header": {
    "version_major": 0,
    "version_minor": 1,
    "version_patch": 0,
    "version_status": "dev",
    "version_build": "custom",
    "version_full_name": "Foundry v0.1.dev.custom",
    "precision": "single"
  },
  "builtin_class_sizes": [
    {
      "build_configuration": "float_64",
      "sizes": [
        { "name": "Nil", "size": 0 },
        { "name": "bool", "size": 1 },
        { "name": "int", "size": 8 },
        { "name": "float", "size": 8 }
      ]
    }
  ],
  "builtin_class_member_offsets": [
    {
      "build_configuration": "float_64",
      "classes": []
    }
  ],
  "global_constants": [],
  "global_enums": [],
  "utility_functions": [],
  "builtin_classes": [],
  "classes": [
    {
      "name": "Object",
      "is_refcounted": false,
      "is_instantiable": true,
      "inherits": null,
      "api_type": "core",
      "brief_description": "",
      "description": "",
      "enums": null,
      "methods": null,
      "properties": null,
      "signals": null,
      "constants": null
    },
    {
      "name": "Node",
      "is_refcounted": false,
      "is_instantiable": true,
      "inherits": "Object",
      "api_type": "core",
      "brief_description": "",
      "description": "",
      "enums": null,
      "methods": [
        {
          "name": "missing_3d_node",
          "is_const": true,
          "is_vararg": false,
          "is_static": false,
          "is_virtual": false,
          "hash": 1,
          "return_value": { "type": "Node3D", "meta": null },
          "arguments": null,
          "description": ""
        }
      ],
      "properties": null,
      "signals": null,
      "constants": null
    }
  ],
  "singletons": [],
  "native_structures": []
}
JSON

cat > "$class_filter" <<'EOF'
Object.swift
Node.swift
Node3D.swift
XRServer.swift
EOF

cat > "$available_class_filter" <<'EOF'
Object.swift
Node.swift
Node3D.swift
XRServer.swift
EOF

cat > "$builtin_filter" <<'EOF'
Vector2.swift
Vector3.swift
EOF

(
    set +e
    swift run Generator "$api_json" "$output_dir" "$tmp_dir/docs" \
        --class-filter "$class_filter" \
        --available-class-filter "$available_class_filter" \
        --builtin-filter "$builtin_filter" >"$tmp_dir/generator.log" 2>&1
    printf '%s\n' "$?" > "$tmp_dir/generator.status"
) 2>>"$tmp_dir/generator.log"

if [[ "$(cat "$tmp_dir/generator.status")" == "0" ]]; then
    if rg -q "Node3D" "$output_dir"; then
        echo "Generator emitted a reference to missing custom-API class Node3D"
        exit 1
    fi

    echo "Generator accepted a custom API reference to missing class Node3D"
    exit 1
fi

if ! rg -q "missing reference type 'Node3D'" "$tmp_dir/generator.log"; then
    echo "Generator failed, but not with the expected missing reference error"
    cat "$tmp_dir/generator.log"
    exit 1
fi
