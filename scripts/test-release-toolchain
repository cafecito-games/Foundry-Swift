#!/usr/bin/env bash
set -euo pipefail

fail() {
    echo "FAIL: $*" >&2
    exit 1
}

rg -q 'FOUNDRY_SWIFT_RELEASE_XCODE:' .github/workflows/release.yml || fail "release workflow must define a pinned Xcode version"
rg -q 'FOUNDRY_SWIFT_RELEASE_XCODE: "26\.4\.1"' .github/workflows/release.yml || fail "release workflow must pin Xcode to 26.4.1, which ships Swift 6.3 and is available on the GitHub-hosted macos-26 runner"
if rg -q 'xcode-version: "latest-stable"|xcode-version: latest-stable' .github/workflows/release.yml; then
    fail "release workflow must not use latest-stable Xcode"
fi
rg -q 'xcode-version: "\$\{\{ env.FOUNDRY_SWIFT_RELEASE_XCODE \}\}"' .github/workflows/release.yml || fail "setup-xcode must use the pinned release Xcode env var"

echo "release toolchain tests passed"
