#!/usr/bin/env bash
set -euo pipefail

failures=0
matches_file="${TMPDIR:-/tmp}/foundry_audit_matches.$$"
trap 'rm -f "$matches_file"' EXIT

require_path() {
  local path="$1"
  if [[ ! -e "$path" ]]; then
    echo "missing required path: $path" >&2
    failures=$((failures + 1))
  fi
}

forbid_path() {
  local path="$1"
  if [[ -e "$path" ]]; then
    echo "forbidden path exists: $path" >&2
    failures=$((failures + 1))
  fi
}

forbid_rg() {
  local pattern="$1"
  local description="$2"
  if rg -n --glob '!.git/**' --glob '!docs/superpowers/**' --glob '!scripts/audit-foundry-product' "$pattern" . >"$matches_file"; then
    echo "forbidden $description:" >&2
    cat "$matches_file" >&2
    failures=$((failures + 1))
  fi
}

require_path Package.swift
require_path Sources/FoundrySwift
require_path Sources/FoundryExtension/include/foundry_extension_interface.h
require_path Sources/ExtensionApi/extension_api.json
require_path Sources/ExtensionApi/foundry_extension_interface.json
require_path Sources/FoundrySwiftEmbed
require_path Tests/FoundrySwiftMacrosTests

forbid_path Sources/SwiftGodot
forbid_path Sources/GDExtension
forbid_path Sources/GDExtension/include/gdextension_interface.h
forbid_path Sources/SwiftGodotMacroLibrary
forbid_path Sources/SwiftGodotTestMacrosLibrary
forbid_path Tests/SwiftGodotMacrosTests

forbid_rg 'SwiftGodot|Swift Godot|swiftgodot' 'SwiftGodot references'
forbid_rg 'GDExtension|gdextension' 'GDExtension references'
forbid_rg '\.gdextension' '.gdextension references'
forbid_rg '@Godot\b' '@Godot macro references'
forbid_rg '#initSwiftExtension\b|initSwiftExtension\b' 'initSwiftExtension references'
forbid_rg 'res://\.godot|/\.godot|^\.godot/' 'legacy Godot cache paths'
forbid_rg 'compatibility_minimum *= *4\.' 'legacy FoundryExtension compatibility floors'
forbid_rg 'config/features=PackedStringArray\("4\.' 'legacy Godot project feature tags'

if find . -path './.git' -prune -o -name '*.gdextension' -print | grep -q .; then
  echo "forbidden .gdextension files remain" >&2
  find . -path './.git' -prune -o -name '*.gdextension' -print >&2
  failures=$((failures + 1))
fi

if find . -path './.git' -prune -o -name 'project.godot' -print | grep -q .; then
  echo "forbidden project.godot files remain" >&2
  find . -path './.git' -prune -o -name 'project.godot' -print >&2
  failures=$((failures + 1))
fi

if rg -n --glob '*.foundryextension' 'compatibility_minimum *= *0\.1\.0' .; then
  echo "found .foundryextension file with unquoted Foundry 0.1 compatibility floor" >&2
  failures=$((failures + 1))
fi

exit "$failures"
