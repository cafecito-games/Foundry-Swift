#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage: scripts/package-foundry-addon TAG FOUNDRYSWIFT_XCFRAMEWORK FOUNDRYSWIFT_EMBED_XCFRAMEWORK [OUTPUT_DIR]

Stages the FoundrySwift Foundry addon at OUTPUT_DIR/dist/addons/FoundrySwift and
writes OUTPUT_DIR/FoundrySwift-TAG.zip. The zip extracts to addons/FoundrySwift.

The addon ships:
  - plugin.cfg, LICENSE
  - FoundrySwiftEmbed.foundryextension      — registered, no-op FoundryExtension
  - bin/ios/FoundrySwift.xcframework
  - bin/ios/FoundrySwiftEmbed.xcframework
  - bin/macos_arm64/FoundrySwift.framework
  - bin/macos_arm64/FoundrySwiftEmbed.framework

The .foundryextension declares FoundrySwift under `[dependencies]` so Foundry's
iOS/macOS exporters embed FoundrySwift.framework into the exported app exactly
once. Downstream FoundryExtensions that link FoundrySwift do NOT need to list it in
their own `[dependencies]` block as long as this addon is installed.
EOF
}

if [[ $# -lt 3 || $# -gt 4 ]]; then
    usage
    exit 1
fi

tag=$1
xcframework=$2
embed_xcframework=$3
output_dir=${4:-.}

case "$tag" in
    ""|*/*)
        echo "TAG must be non-empty and must not contain /"
        exit 1
        ;;
esac

absolute_path() {
    case "$1" in
        /*)
            printf '%s\n' "$1"
            ;;
        *)
            printf '%s/%s\n' "$(pwd)" "$1"
            ;;
    esac
}

xcframework=$(absolute_path "$xcframework")
embed_xcframework=$(absolute_path "$embed_xcframework")
output_dir=$(absolute_path "$output_dir")

if [[ ! -d "$xcframework" ]]; then
    echo "Expected FoundrySwift xcframework directory: $xcframework"
    exit 1
fi

if [[ ! -d "$embed_xcframework" ]]; then
    echo "Expected FoundrySwiftEmbed xcframework directory: $embed_xcframework"
    exit 1
fi

if [[ ! -f LICENSE ]]; then
    echo "Expected to run from the FoundrySwift repository root"
    exit 1
fi

copy_without_symlinks() {
    local source=$1
    local destination_parent=$2

    # gpm refuses to extract symlink entries from release zips. Dereference
    # framework symlinks into real files/directories while preserving paths.
    rsync -aL "$source" "$destination_parent/"
}

# Pick the macOS arm64 slice from an xcframework. Falls back to a unique
# macos-* slice when no exact "macos-arm64" directory exists.
pick_macos_framework() {
    local xcf=$1
    local module=$2
    local resolved

    if [[ -d "$xcf/macos-arm64/$module.framework" ]]; then
        printf '%s\n' "$xcf/macos-arm64/$module.framework"
        return
    fi

    local candidates=()
    for candidate in "$xcf"/macos-*/"$module.framework"; do
        [[ -d "$candidate" ]] && candidates+=("$candidate")
    done

    if [[ ${#candidates[@]} -eq 1 ]]; then
        printf '%s\n' "${candidates[0]}"
        return
    fi

    echo "Expected exactly one macOS $module.framework slice in $xcf"
    exit 1
}

mac_framework=$(pick_macos_framework "$xcframework" "FoundrySwift")
mac_embed_framework=$(pick_macos_framework "$embed_xcframework" "FoundrySwiftEmbed")

mkdir -p "$output_dir"

dist_dir="$output_dir/dist"
addon_dir="$dist_dir/addons/FoundrySwift"
zip_path="$output_dir/FoundrySwift-$tag.zip"
plugin_version=${tag#v}

rm -rf "$addon_dir"
mkdir -p "$addon_dir/bin/ios" "$addon_dir/bin/macos_arm64"

cat > "$addon_dir/plugin.cfg" <<EOF
[plugin]
name="FoundrySwift"
description="Shared FoundrySwift xcframework/framework for iOS/macOS FoundryExtensions. Registers a no-op FoundrySwiftEmbed extension that owns embedding FoundrySwift.framework into exported apps; downstream FoundryExtensions should not list FoundrySwift in their own [dependencies]."
author="cafecito-games"
version="$plugin_version"
script=""
EOF

cat > "$addon_dir/FoundrySwiftEmbed.foundryextension" <<'EOF'
[configuration]
entry_symbol = "foundry_swift_embed_entry_point"
compatibility_minimum = "0.1.0"

[libraries]
ios.debug = "res://addons/FoundrySwift/bin/ios/FoundrySwiftEmbed.xcframework"
ios.release = "res://addons/FoundrySwift/bin/ios/FoundrySwiftEmbed.xcframework"
ios.simulator.debug = "res://addons/FoundrySwift/bin/ios/FoundrySwiftEmbed.xcframework"
ios.simulator.release = "res://addons/FoundrySwift/bin/ios/FoundrySwiftEmbed.xcframework"
macos.arm64 = "res://addons/FoundrySwift/bin/macos_arm64/FoundrySwiftEmbed.framework"

[dependencies]
ios.debug = { "res://addons/FoundrySwift/bin/ios/FoundrySwift.xcframework": "" }
ios.release = { "res://addons/FoundrySwift/bin/ios/FoundrySwift.xcframework": "" }
ios.simulator.debug = { "res://addons/FoundrySwift/bin/ios/FoundrySwift.xcframework": "" }
ios.simulator.release = { "res://addons/FoundrySwift/bin/ios/FoundrySwift.xcframework": "" }
macos.arm64 = { "res://addons/FoundrySwift/bin/macos_arm64/FoundrySwift.framework": "" }
EOF

cp LICENSE "$addon_dir/LICENSE"
copy_without_symlinks "$xcframework" "$addon_dir/bin/ios"
copy_without_symlinks "$embed_xcframework" "$addon_dir/bin/ios"
copy_without_symlinks "$mac_framework" "$addon_dir/bin/macos_arm64"
copy_without_symlinks "$mac_embed_framework" "$addon_dir/bin/macos_arm64"

if find "$addon_dir" -type l -print | grep -q .; then
    echo "Refusing to package addon with symlinks; gpm cannot extract them:"
    find "$addon_dir" -type l -print
    exit 1
fi

rm -f "$zip_path"
(
    cd "$dist_dir"
    zip -qryX "$zip_path" addons/FoundrySwift
)

printf '%s\n' "$zip_path"
